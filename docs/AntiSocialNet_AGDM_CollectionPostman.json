{
  "info": {
    "name": "UnaHur Anti-Social Net - AGDM",
    "description": "Colección de pruebas para la API de UnaHur Anti-Social Net. Incluye las 4 entidades: Users, Posts, Comments y Tags.\n\nVariables:\n- base_url: URL base de la API (por defecto http://localhost:3000)\n- userId, postId, commentId, tagId, imageId: IDs para reutilizar entre requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "nickName", "value": "andres123" },
    { "key": "nickNameSeguido", "value": "juan456" },
    { "key": "userId", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "commentId", "value": "" },
    { "key": "tagId", "value": "" },
    { "key": "imageId", "value": "" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Obtener todos los usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickName\": \"andres123\",\n  \"email\": \"andres@mail.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Obtener usuario por nickName",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/{{nickName}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{nickName}}"]
            }
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo@mail.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{nickName}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{nickName}}"]
            }
          }
        },
        {
          "name": "Eliminar usuario",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/{{nickName}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{nickName}}"]
            }
          }
        },
        {
          "name": "Seguir usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seguir\": \"{{nickNameSeguido}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{nickName}}/follow",
              "host": ["{{base_url}}"],
              "path": ["users", "{{nickName}}", "follow"]
            }
          }
        },
        {
          "name": "Dejar de seguir usuario",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seguir\": \"{{nickNameSeguido}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{nickName}}/unfollow",
              "host": ["{{base_url}}"],
              "path": ["users", "{{nickName}}", "unfollow"]
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Obtener todos los posts",
          "request": {
            "method": "GET",
