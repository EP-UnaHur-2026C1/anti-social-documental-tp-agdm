            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Actualizar post",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Descripción actualizada\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/{{postId}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{postId}}"]
            }
          }
        },
        {
          "name": "Eliminar post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{postId}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{postId}}"]
            }
          }
        },
        {
          "name": "Agregar imagen a post",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://ejemplo.com/imagen.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/{{postId}}/images",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{postId}}", "images"]
            }
          }
        },
        {
          "name": "Eliminar imagen de post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{postId}}/images/{{imageId}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{postId}}", "images", "{{imageId}}"]
            }
          }
        },
        {
          "name": "Asociar tag a post",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{postId}}/tags/{{tagId}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{postId}}", "tags", "{{tagId}}"]
            }
          }
        },
        {
          "name": "Quitar tag de post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{postId}}/tags/{{tagId}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{postId}}", "tags", "{{tagId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Obtener comentarios de un post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/comments/post/{{postId}}",
              "host": ["{{base_url}}"],
              "path": ["comments", "post", "{{postId}}"]
            }
          }
        },
        {
          "name": "Crear comentario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Este es un comentario\",\n  \"user\": \"{{userId}}\",\n  \"post\": \"{{postId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/comments",
              "host": ["{{base_url}}"],
              "path": ["comments"]
            }
          }
        },
        {
          "name": "Actualizar comentario",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Comentario actualizado\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/comments/{{commentId}}",
              "host": ["{{base_url}}"],
              "path": ["comments", "{{commentId}}"]
            }
          }
        },
        {
          "name": "Eliminar comentario",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/comments/{{commentId}}",
              "host": ["{{base_url}}"],
              "path": ["comments", "{{commentId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Obtener todos los tags",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tags",
              "host": ["{{base_url}}"],
              "path": ["tags"]
